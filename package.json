{
  "name": "apollo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0 --port 1420 --strictPort",
    "build": "vue-tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run && cargo test --manifest-path src-tauri/Cargo.toml",
    "test:watch": "vitest",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write . && cargo fmt --manifest-path src-tauri/Cargo.toml --all",
    "format:check": "prettier --check . && cargo fmt --manifest-path src-tauri/Cargo.toml --all --check",
    "typecheck": "vue-tsc --noEmit",
    "clippy": "cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets --all-features -- -D warnings",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.0",
    "lucide-vue-next": "^1.0.0",
    "vue": "^3.5.13"
  },
  "devDependencies": {
    "@eslint/js": "^9.25.1",
    "@tauri-apps/cli": "^2.10.0",
    "@types/node": "^24.0.10",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/test-utils": "^2.4.6",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.25.1",
    "eslint-plugin-vue": "^10.0.0",
    "globals": "^16.0.0",
    "jsdom": "^26.1.0",
    "postcss": "^8.4.49",
    "prettier": "^3.5.3",
    "tailwindcss": "^3.4.17",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.30.1",
    "vite": "^7.0.6",
    "vitest": "^3.1.1",
    "vue-eslint-parser": "^10.1.0",
    "vue-tsc": "^3.0.0"
  }
}
